{
  "expo": {
    "name": "KovariyaApp",
    "slug": "kovariya-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/kovariya-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/kovariya-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kovariya.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow KovariyaApp to record voice notes for mission evidence."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/kovariya-adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kovariya.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/kovariya-favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to attach mission evidence."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
